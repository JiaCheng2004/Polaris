{
  "title": "Polaris Overview",
  "uid": "polaris-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["polaris", "gateway"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Requests Total",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(polaris_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Provider Errors",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(polaris_provider_errors_total[5m])) by (provider)",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    }
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}
