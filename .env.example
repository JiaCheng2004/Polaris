# Polaris local environment example
#
# Copy to .env for local Docker Compose usage.

COMPOSE_PROJECT_NAME=polaris
POLARIS_PORT=8080
POLARIS_BOOTSTRAP_ADMIN_KEY_HASH=
POLARIS_OTEL_ENDPOINT=
POLARIS_OTEL_SERVICE_NAME=polaris
POLARIS_OTEL_INSECURE=true
POLARIS_OTEL_SAMPLE_RATIO=1.0

# Optional for Phase 1 chat providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional for current Phase 2 chat providers.
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_VERTEX_JOB_SECRET=
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_OPENSPEECH_APP_ID=
VOLCENGINE_OPENSPEECH_API_KEY=
VOLCENGINE_OPENSPEECH_ACCESS_TOKEN=
MINIMAX_API_KEY=
# Global Token Plan default. Override to https://api.minimaxi.com for China mainland accounts.
MINIMAX_BASE_URL=https://api.minimax.io
ELEVENLABS_API_KEY=
XAI_API_KEY=
DASHSCOPE_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=
FIREWORKS_API_KEY=
FEATHERLESS_API_KEY=
MOONSHOT_API_KEY=
GLM_API_KEY=
MISTRAL_API_KEY=
AWS_BEDROCK_ACCESS_KEY_ID=
AWS_BEDROCK_SECRET_ACCESS_KEY=
AWS_BEDROCK_SESSION_TOKEN=
AWS_BEDROCK_REGION=us-east-1
NVIDIA_API_KEY=
REPLICATE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional for Google Vertex live smoke via ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional for production-shaped or dev stacks.
POSTGRES_USER=polaris
POSTGRES_PASSWORD=polaris
POSTGRES_DB=polaris
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
PGADMIN_DEFAULT_EMAIL=admin@polaris.local
PGADMIN_DEFAULT_PASSWORD=admin

# Optional validation toggles.
POLARIS_LIVE_SMOKE=0
POLARIS_LIVE_SMOKE_STRICT=0
# Optional preview validation toggle for ElevenLabs music.
POLARIS_LIVE_SMOKE_ELEVENLABS=0
